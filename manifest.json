{
  "manifest_version": 3,
  "name": "Figma Capture for Localhost",
  "description": "Click the extension icon to inject Figma capture script on localhost pages. Works with Figma MCP + Claude Code.",
  "version": "1.1.0",
  "permissions": ["scripting", "activeTab", "webNavigation", "tabs"],
  "host_permissions": [
    "http://localhost/*",
    "https://localhost/*",
    "http://127.0.0.1/*",
    "https://127.0.0.1/*",
    "http://0.0.0.0/*",
    "https://mcp.figma.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Figma Capture",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
